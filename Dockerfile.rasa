FROM rasa/rasa:3.6.21

WORKDIR /app

COPY config.yml domain.yml credentials.yml ./
COPY data ./data
COPY start-rasa.sh ./start-rasa.sh
COPY render_proxy.py ./render_proxy.py

USER root
RUN chmod +x /app/start-rasa.sh \
    && chown -R 1001:0 /app \
    && chmod -R g=u /app

USER 1001
RUN rasa train --out models

ENTRYPOINT []
CMD ["/bin/sh", "/app/start-rasa.sh"]
